{
    email {$SITE_EMAIL}
}

{$SITE_DOMAIN} {
    encode zstd gzip

    @primary host {$PRIMARY_DOMAIN}
    @blocked_paths {
        path /.env*
        path /.git*
        path /composer.*
        path /docker-compose*
        path /deploy.sh
        path /runtime/*
        path /vendor/*
        path /docker/*
        path /kernel/Install/*
    }
    respond @blocked_paths 404

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        X-Frame-Options SAMEORIGIN
        -Server
    }

    handle @primary {
        respond @blocked_paths 404
        reverse_proxy app:80
    }

    handle {
        redir https://{$PRIMARY_DOMAIN}{uri} permanent
    }
}
