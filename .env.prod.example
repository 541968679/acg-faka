APP_DEBUG=0

# Caddy accepts one or more hostnames. Keep the space after the comma.
SITE_DOMAIN=shop.example.com, example.com, www.example.com
PRIMARY_DOMAIN=shop.example.com
SITE_URL=https://shop.example.com
SITE_EMAIL=admin@example.com

DB_HOST=db
DB_PORT=3306
DB_DATABASE=acgfaka
DB_USERNAME=faka
DB_PASSWORD=change_this_database_password
MYSQL_ROOT_PASSWORD=change_this_mysql_root_password
DB_PREFIX=acg_

STORE_APP_ID=
STORE_APP_KEY=

EPAY_API_URL=https://api.xunhupay.com/payment/do.html
EPAY_ALIPAY_APPID=
EPAY_ALIPAY_APPSECRET=
EPAY_WECHAT_APPID=
EPAY_WECHAT_APPSECRET=

# Legacy single-channel fallback for older HuPiJiao/Epay deployments.
# Prefer the channel-specific EPAY_ALIPAY_* and EPAY_WECHAT_* variables above.
EPAY_APPID=
EPAY_APPSECRET=

ORDER_CLEANUP_INTERVAL=60

# Initial admin user. These are used only when the MySQL data volume is created
# for the first time.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password
ADMIN_NICKNAME=Admin
ADMIN_SALT=change_this_random_admin_salt

# Optional: only needed if you enable sub-stations/custom shop domains.
CNAME_DOMAIN=
SUBSTATION_DOMAINS=
